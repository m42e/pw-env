#!/bin/sh
# Stub 1Password CLI for the command-scoped demo.
# Responds to the only two references used in .env.

case "$1" in
  read)
    case "$2" in
      "op://Demo/api-key/password") printf 's3cr3t-api-key' ;;
      "op://Demo/db/password")      printf 's3cr3t-db-pass' ;;
      *) printf 'Error: item not found\n' >&2; exit 1 ;;
    esac
    ;;
  *)
    printf 'stub op: unsupported command: %s\n' "$1" >&2
    exit 1
    ;;
esac
